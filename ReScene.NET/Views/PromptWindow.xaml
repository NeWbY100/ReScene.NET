<Window x:Class="ReScene.NET.Views.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="560" Height="160"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource ForegroundPrimary}"
        FontFamily="{DynamicResource UIFontFamily}"
        ResizeMode="NoResize">
  <DockPanel Margin="{DynamicResource PageMargin}">
    <TextBlock x:Name="MessageBlock"
               DockPanel.Dock="Top"
               Margin="0,0,0,6"
               TextWrapping="Wrap"
               Foreground="{DynamicResource ForegroundPrimary}" />

    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,8,0,0">
      <Button Content="Cancel"
              Click="OnCancelClick"
              IsCancel="True"
              Style="{StaticResource GhostButton}"
              MinWidth="75"
              Margin="4,0,0,0" />
      <Button Content="OK"
              Click="OnOkClick"
              IsDefault="True"
              Style="{StaticResource PrimaryButton}"
              MinWidth="75"
              Margin="4,0,0,0" />
    </StackPanel>

    <TextBox x:Name="InputBox"
             VerticalAlignment="Center"
             FontFamily="{DynamicResource UIFontFamily}"
             FontSize="{DynamicResource FontSizeBody}" />
  </DockPanel>
</Window>
